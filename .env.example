# Affiliate redirect – krævet for produktionsdeploy
AFFILIATE_BASE_URL=https://example.com/loan-offers
AFFILIATE_CAMPAIGN=tco_mvp

# Analytics (valgfri)
ANALYTICS_PROVIDER=ga4|none
GA4_MEASUREMENT_ID=

# Site URL (til metadata/canonical)
SITE_URL=https://example.com

# PostgreSQL – lagring af leads fra "Hvad kan jeg købe bolig for?" (påkrævet i produktion)
# Opret tabellen med sql/loan_calc_leads.sql
# Brug DATABASE_URL lokalt. På Vercel + Neon sættes ofte DATABASE_POSTGRES_URL – API understøtter begge.
DATABASE_URL=

# Artikel-feedback (Resend) – påkrævet for formularen nederst på artikler
# Opret API-nøgle på https://resend.com – verificer domæne og brug afsender fra dit domæne i produktion.
RESEND_API_KEY=
# Modtager (standard: info@boligklarhed.dk)
ARTICLE_FEEDBACK_TO_EMAIL=info@boligklarhed.dk
# Afsender – i test kan Resends onboarding-adresse bruges; i produktion: fx "Boligklarhed <kontakt@boligklarhed.dk>"
ARTICLE_FEEDBACK_FROM_EMAIL=
